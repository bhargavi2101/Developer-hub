# MongoDB Configuration
MONGO_URI=mongodb+srv://your-username:your-password@cluster0.example.mongodb.net/devhub?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your_secure_jwt_secret_key_here
JWT_REFRESH_SECRET=your_refresh_token_secret_key_here

# CORS Configuration - UPDATE THIS WITH YOUR DEPLOYED FRONTEND URL
ALLOWED_ORIGINS=https://your-frontend-domain.vercel.app,https://your-frontend-domain.vercel.app

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@developerhub.com

# Frontend URL - UPDATE THIS WITH YOUR DEPLOYED FRONTEND URL
FRONTEND_URL=https://your-frontend-domain.vercel.app

# File Upload Configuration
UPLOAD_DIR=uploads
AVATAR_DIR=uploads/avatars
MAX_FILE_SIZE=2097152
ALLOWED_FILE_TYPES=image/jpeg,image/jpg,image/png,image/gif,image/webp

# Security Configuration
NODE_ENV=production
SESSION_SECRET=your_session_secret_key_here